{
  "rules": {
    "parties": {
      "$partyCode": {
        ".read": "auth != null",
        ".write": "auth != null",
        "members": {
          "$uid": {
            ".write": "auth.uid === $uid"
          }
        }
      }
    },
    "games": {
      "$gameId": {
        ".read": "auth != null",
        "players": {
          "$uid": {
            ".write": "auth.uid === $uid"
          }
        }
      }
    }
  }
}
